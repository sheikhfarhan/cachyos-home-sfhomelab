networks:
  dockerapps-net:
    external: true
    
services:
  jellyfin-shadow:
    image: lscr.io/linuxserver/jellyfin:latest
    container_name: jellyfin-shadow
    networks:
      dockerapps-net:
        ipv4_address: 172.20.0.34
        ipv6_address: fd00:dead:beef:2::34
    group_add:
      - "983" # Add the video GID
      - "987" # Add the render GID
    environment:
      - PUID=1000 # Change to your actual PUID if different
      - PGID=1000 # Change to your actual PGID if different
      - TZ=Asia/Singapore
    volumes:
      # 1. ISOLATED CONFIG: These create fresh, empty folders in your test directory
      - /home/sfarhan/homelab/cachyos-home/media-stack/jellyfin-shadow/config:/config
      - /home/sfarhan/homelab/cachyos-home/media-stack/jellyfin-shadow/cache:/cache
      
      # 2. READ-ONLY MEDIA: Point this to your actual media folder, but add ':ro'
      # The 'ro' stands for Read-Only. This guarantees the shadow instance 
      # physically cannot delete or alter your real media files.
      - /mnt/vault/media:/media:ro
    ports:
      # 3. THE NEW PORT: We bind ONLY to NetBird, and use port 8097 
      # so it doesn't crash into your production instance on 8096.
      - "10.80.0.1:8097:8096"
    devices:
      # Pass the entire Direct Rendering Interface directory
      - /dev/dri:/dev/dri
    restart: unless-stopped